generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum AccountType {
  CASH
  BANK
  CREDIT_CARD
  E_WALLET
  SAVINGS
  FIXED_DEPOSIT
  RETIREMENT
  INVESTMENT
}

enum TransactionKind {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionStatus {
  DRAFT
  POSTED
  VOID
}

enum FrequencyType {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum ReminderStatus {
  PENDING
  PAID
  MISSED
  CANCELLED
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  PAUSED
  CANCELLED
}

enum SalaryComponentType {
  BASIC
  ALLOWANCE
  BONUS
  OVERTIME
  REIMBURSEMENT
  DEDUCTION
  TAX
  OTHER
}

enum ReimbursementStatus {
  PENDING
  APPROVED
  RECEIVED
  REJECTED
  CANCELLED
}

enum LiabilityType {
  LOAN
  EMI
  CREDIT_CARD
  MORTGAGE
  LEASE
  OTHER
}

enum LiabilityStatus {
  ACTIVE
  CLOSED
  DEFAULTED
}

enum InstallmentStatus {
  PENDING
  PARTIAL
  PAID
  MISSED
  CANCELLED
}

enum SnapshotStatus {
  OPEN
  LOCKED
  ARCHIVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  RESTORE
  IMPORT
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

enum InvestmentAccountType {
  STOCK
  MUTUAL_FUND
  ETF
  BOND
  RETIREMENT
  FIXED_DEPOSIT
  CRYPTO
  OTHER
}

enum InvestmentTransactionType {
  BUY
  SELL
  DIVIDEND
  INTEREST
  FEE
  ADJUSTMENT
}

model User {
  id                 String                       @id @default(uuid()) @db.Uuid
  fullName           String                       @db.VarChar(150)
  email              String                       @unique @db.VarChar(150)
  mobileNo           String?                      @db.VarChar(30)
  passwordHash       String                       @db.VarChar(500)
  isActive           Boolean                      @default(true)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  profile            UserProfile?
  categories         Category[]
  merchants          Merchant[]
  tags               Tag[]
  accounts           FinancialAccount[]
  transactions       Transaction[]
  budgets            Budget[]
  recurringTemplates RecurringTransactionTemplate[]
  reminders          BillReminder[]
  savingsGoals       SavingsGoal[]
  incomeSources      IncomeSource[]
  salaryPayments     SalaryPayment[]
  reimbursementClaims ReimbursementClaim[]
  liabilityAccounts  LiabilityAccount[]
  monthlySnapshots   MonthlyFinancialSnapshot[]
  auditLogs          AuditLog[]
  importJobs         ImportJob[]
  investmentAccounts InvestmentAccount[]
}

model UserProfile {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @unique @db.Uuid
  defaultCurrencyCode    String    @default("LKR") @db.VarChar(10)
  country                String?   @db.VarChar(100)
  salaryDay              Int?
  financialMonthStartDay Int?
  timeZone               String?   @db.VarChar(100)
  occupation             String?   @db.VarChar(100)
  employerName           String?   @db.VarChar(150)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @db.Uuid
  type              CategoryType
  name              String       @db.VarChar(100)
  parentCategoryId  String?      @db.Uuid
  icon              String?      @db.VarChar(50)
  colorCode         String?      @db.VarChar(20)
  sortOrder         Int          @default(0)
  isSystemDefined   Boolean      @default(false)
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentCategory    Category?    @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  subCategories     Category[]   @relation("CategoryHierarchy")
  transactions      Transaction[]
  transactionSplits TransactionSplit[]
  budgetItems        BudgetCategory[]
  reminders          BillReminder[]
  recurringTemplates RecurringTransactionTemplate[]
  incomeSources      IncomeSource[]           @relation("IncomeSourceCategory")
  reimbursementClaims ReimbursementClaim[]

  @@index([userId])
  @@index([parentCategoryId])
  @@unique([userId, type, name])
}

model Merchant {
  id                 String                       @id @default(uuid()) @db.Uuid
  userId             String                       @db.Uuid
  name               String                       @db.VarChar(150)
  merchantType       String?                      @db.VarChar(50)
  contactNo          String?                      @db.VarChar(30)
  notes              String?
  isActive           Boolean                      @default(true)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  user               User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       Transaction[]
  recurringTemplates RecurringTransactionTemplate[]

  @@index([userId])
  @@unique([userId, name])
}

model Tag {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @db.Uuid
  name            String           @db.VarChar(50)
  createdAt       DateTime         @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionTags TransactionTag[]

  @@index([userId])
  @@unique([userId, name])
}

model FinancialAccount {
  id                   String                       @id @default(uuid()) @db.Uuid
  userId               String                       @db.Uuid
  type                 AccountType
  currencyCode         String                       @default("LKR") @db.VarChar(10)
  name                 String                       @db.VarChar(100)
  institutionName      String?                      @db.VarChar(150)
  accountNumberMasked  String?                      @db.VarChar(50)
  openingBalance       Decimal                      @default(0) @db.Decimal(18, 2)
  currentBalance       Decimal                      @default(0) @db.Decimal(18, 2)
  creditLimit          Decimal?                     @db.Decimal(18, 2)
  statementDay         Int?
  paymentDueDay        Int?
  isIncludedInNetWorth Boolean                      @default(true)
  isArchived           Boolean                      @default(false)
  openedDate           DateTime?                    @db.Date
  closedDate           DateTime?                    @db.Date
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  user                 User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromTransactions     Transaction[]                @relation("FromAccountTransactions")
  toTransactions       Transaction[]                @relation("ToAccountTransactions")
  recurringFrom        RecurringTransactionTemplate[] @relation("RecurringFromAccount")
  recurringTo          RecurringTransactionTemplate[] @relation("RecurringToAccount")

  @@index([userId])
  @@unique([userId, name])
}

model Transaction {
  id                  String              @id @default(uuid()) @db.Uuid
  userId              String              @db.Uuid
  transactionNo       String              @unique @db.VarChar(30)
  transactionDate     DateTime
  postedDate          DateTime?
  kind                TransactionKind
  status              TransactionStatus   @default(POSTED)
  fromAccountId       String?             @db.Uuid
  toAccountId         String?             @db.Uuid
  categoryId          String?             @db.Uuid
  merchantId          String?             @db.Uuid
  amount              Decimal             @db.Decimal(18, 2)
  currencyCode        String              @default("LKR") @db.VarChar(10)
  exchangeRate        Decimal             @default(1) @db.Decimal(18, 6)
  referenceNo         String?             @db.VarChar(100)
  notes               String?
  paymentMethod       String?             @db.VarChar(50)
  location            String?             @db.VarChar(150)
  isRecurringGenerated Boolean            @default(false)
  recurringTemplateId String?             @db.Uuid
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount         FinancialAccount?   @relation("FromAccountTransactions", fields: [fromAccountId], references: [id], onDelete: SetNull)
  toAccount           FinancialAccount?   @relation("ToAccountTransactions", fields: [toAccountId], references: [id], onDelete: SetNull)
  category            Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  merchant            Merchant?           @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  recurringTemplate   RecurringTransactionTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)

  splits              TransactionSplit[]
  tags                TransactionTag[]
  attachments         TransactionAttachment[]
  linkedReminder      BillReminder?
  salaryPayment       SalaryPayment?          @relation("SalaryPaymentTransaction")
  reimbursementClaim  ReimbursementClaim?     @relation("ReimbursementTransaction")
  liabilityInstallment LiabilityInstallment?  @relation("LiabilityInstallmentTransaction")

  @@index([userId])
  @@index([transactionDate])
  @@index([kind])
  @@index([categoryId])
  @@index([merchantId])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([recurringTemplateId])
}

model TransactionSplit {
  id             String       @id @default(uuid()) @db.Uuid
  transactionId  String       @db.Uuid
  categoryId     String       @db.Uuid
  amount         Decimal      @db.Decimal(18, 2)
  notes          String?
  createdAt      DateTime     @default(now())

  transaction    Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([transactionId])
  @@index([categoryId])
}

model TransactionTag {
  id             String       @id @default(uuid()) @db.Uuid
  transactionId  String       @db.Uuid
  tagId          String       @db.Uuid

  transaction    Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([transactionId, tagId])
  @@index([tagId])
}

model TransactionAttachment {
  id             String       @id @default(uuid()) @db.Uuid
  transactionId  String       @db.Uuid
  fileName       String       @db.VarChar(255)
  fileUrl        String       @db.VarChar(500)
  fileType       String?      @db.VarChar(50)
  uploadedAt     DateTime     @default(now())

  transaction    Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

model Budget {
  id                     String           @id @default(uuid()) @db.Uuid
  userId                 String           @db.Uuid
  name                   String           @db.VarChar(100)
  startDate              DateTime         @db.Date
  endDate                DateTime         @db.Date
  currencyCode           String           @default("LKR") @db.VarChar(10)
  budgetAmount           Decimal          @db.Decimal(18, 2)
  alertThresholdPercent  Decimal?         @db.Decimal(5, 2)
  isActive               Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  user                   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories             BudgetCategory[]

  @@index([userId])
  @@index([startDate, endDate])
}

model BudgetCategory {
  id              String    @id @default(uuid()) @db.Uuid
  budgetId        String    @db.Uuid
  categoryId      String    @db.Uuid
  allocatedAmount Decimal   @db.Decimal(18, 2)
  warningPercent  Decimal?  @db.Decimal(5, 2)

  budget          Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([budgetId, categoryId])
  @@index([categoryId])
}

model RecurringTransactionTemplate {
  id                 String            @id @default(uuid()) @db.Uuid
  userId             String            @db.Uuid
  templateName       String            @db.VarChar(100)
  kind               TransactionKind
  fromAccountId      String?           @db.Uuid
  toAccountId        String?           @db.Uuid
  categoryId         String?           @db.Uuid
  merchantId         String?           @db.Uuid
  amount             Decimal           @db.Decimal(18, 2)
  frequencyType      FrequencyType
  frequencyInterval  Int               @default(1)
  nextRunDate        DateTime          @db.Date
  endDate            DateTime?         @db.Date
  autoPost           Boolean           @default(false)
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount        FinancialAccount? @relation("RecurringFromAccount", fields: [fromAccountId], references: [id], onDelete: SetNull)
  toAccount          FinancialAccount? @relation("RecurringToAccount", fields: [toAccountId], references: [id], onDelete: SetNull)
  category           Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  merchant           Merchant?         @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  generatedTransactions Transaction[]

  @@index([userId])
  @@index([nextRunDate])
  @@index([isActive])
}

model BillReminder {
  id                  String          @id @default(uuid()) @db.Uuid
  userId              String          @db.Uuid
  categoryId          String?         @db.Uuid
  linkedTransactionId String?         @unique @db.Uuid
  reminderTitle       String          @db.VarChar(100)
  amountExpected      Decimal?        @db.Decimal(18, 2)
  dueDate             DateTime        @db.Date
  reminderDaysBefore  Int             @default(1)
  isPaid              Boolean         @default(false)
  status              ReminderStatus  @default(PENDING)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category            Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  linkedTransaction   Transaction?    @relation(fields: [linkedTransactionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([dueDate])
  @@index([status])
}

model SavingsGoal {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @db.Uuid
  goalName        String      @db.VarChar(120)
  targetAmount    Decimal     @db.Decimal(18, 2)
  currentAmount   Decimal     @default(0) @db.Decimal(18, 2)
  currencyCode    String      @default("LKR") @db.VarChar(10)
  targetDate      DateTime?   @db.Date
  status          GoalStatus  @default(ACTIVE)
  notes           String?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model IncomeSource {
  id                String     @id @default(uuid()) @db.Uuid
  userId            String     @db.Uuid
  defaultCategoryId String?    @db.Uuid
  sourceName        String     @db.VarChar(120)
  sourceType        String?    @db.VarChar(50)
  employerName      String?    @db.VarChar(150)
  defaultAmount     Decimal?   @db.Decimal(18, 2)
  payDay            Int?
  isTaxable         Boolean    @default(false)
  isActive          Boolean    @default(true)
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultCategory   Category?  @relation("IncomeSourceCategory", fields: [defaultCategoryId], references: [id], onDelete: SetNull)
  salaryPayments    SalaryPayment[]

  @@index([userId])
  @@index([defaultCategoryId])
  @@unique([userId, sourceName])
}

model SalaryPayment {
  id                  String              @id @default(uuid()) @db.Uuid
  userId              String              @db.Uuid
  incomeSourceId      String?             @db.Uuid
  linkedTransactionId String?             @unique @db.Uuid
  salaryMonth         DateTime            @db.Date
  payDate             DateTime            @db.Date
  basicAmount         Decimal             @default(0) @db.Decimal(18, 2)
  grossAmount         Decimal             @default(0) @db.Decimal(18, 2)
  deductionAmount     Decimal             @default(0) @db.Decimal(18, 2)
  netAmount           Decimal             @default(0) @db.Decimal(18, 2)
  currencyCode        String              @default("LKR") @db.VarChar(10)
  status              TransactionStatus   @default(POSTED)
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeSource        IncomeSource?       @relation(fields: [incomeSourceId], references: [id], onDelete: SetNull)
  linkedTransaction   Transaction?        @relation("SalaryPaymentTransaction", fields: [linkedTransactionId], references: [id], onDelete: SetNull)
  components          SalaryComponent[]

  @@index([userId])
  @@index([incomeSourceId])
  @@index([salaryMonth])
  @@index([payDate])
}

model SalaryComponent {
  id                String               @id @default(uuid()) @db.Uuid
  salaryPaymentId   String               @db.Uuid
  componentType     SalaryComponentType
  componentName     String               @db.VarChar(100)
  amount            Decimal              @db.Decimal(18, 2)
  isTaxable         Boolean              @default(false)
  displayOrder      Int                  @default(0)
  notes             String?

  salaryPayment     SalaryPayment        @relation(fields: [salaryPaymentId], references: [id], onDelete: Cascade)

  @@index([salaryPaymentId])
}

model ReimbursementClaim {
  id                  String               @id @default(uuid()) @db.Uuid
  userId              String               @db.Uuid
  categoryId          String?              @db.Uuid
  linkedTransactionId String?              @unique @db.Uuid
  claimNo             String               @unique @db.VarChar(30)
  title               String               @db.VarChar(120)
  description         String?
  claimDate           DateTime             @db.Date
  amountClaimed       Decimal              @db.Decimal(18, 2)
  amountReceived      Decimal              @default(0) @db.Decimal(18, 2)
  receivedDate        DateTime?            @db.Date
  employerName        String?              @db.VarChar(150)
  isTaxDeductible     Boolean              @default(false)
  status              ReimbursementStatus  @default(PENDING)
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category            Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  linkedTransaction   Transaction?         @relation("ReimbursementTransaction", fields: [linkedTransactionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([categoryId])
  @@index([claimDate])
  @@index([status])
}

model LiabilityAccount {
  id                  String           @id @default(uuid()) @db.Uuid
  userId              String           @db.Uuid
  accountName         String           @db.VarChar(120)
  liabilityType       LiabilityType
  lenderName          String?          @db.VarChar(150)
  accountNumberMasked String?          @db.VarChar(50)
  principalAmount     Decimal          @db.Decimal(18, 2)
  outstandingAmount   Decimal          @db.Decimal(18, 2)
  interestRate        Decimal?         @db.Decimal(8, 4)
  emiAmount           Decimal?         @db.Decimal(18, 2)
  currencyCode        String           @default("LKR") @db.VarChar(10)
  startDate           DateTime?        @db.Date
  endDate             DateTime?        @db.Date
  dueDay              Int?
  status              LiabilityStatus  @default(ACTIVE)
  isActive            Boolean          @default(true)
  notes               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments        LiabilityInstallment[]

  @@index([userId])
  @@index([status])
}

model LiabilityInstallment {
  id                  String             @id @default(uuid()) @db.Uuid
  liabilityAccountId  String             @db.Uuid
  linkedTransactionId String?            @unique @db.Uuid
  installmentNo       Int
  dueDate             DateTime           @db.Date
  principalDue        Decimal            @default(0) @db.Decimal(18, 2)
  interestDue         Decimal            @default(0) @db.Decimal(18, 2)
  totalDue            Decimal            @db.Decimal(18, 2)
  amountPaid          Decimal            @default(0) @db.Decimal(18, 2)
  paidDate            DateTime?          @db.Date
  status              InstallmentStatus  @default(PENDING)
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  liabilityAccount    LiabilityAccount   @relation(fields: [liabilityAccountId], references: [id], onDelete: Cascade)
  linkedTransaction   Transaction?       @relation("LiabilityInstallmentTransaction", fields: [linkedTransactionId], references: [id], onDelete: SetNull)

  @@unique([liabilityAccountId, installmentNo])
  @@index([liabilityAccountId])
  @@index([dueDate])
  @@index([status])
}

model InvestmentAccount {
  id                  String                @id @default(uuid()) @db.Uuid
  userId              String                @db.Uuid
  accountName         String                @db.VarChar(120)
  accountType         InvestmentAccountType
  institutionName     String?               @db.VarChar(150)
  currencyCode        String                @default("LKR") @db.VarChar(10)
  costBasis           Decimal               @default(0) @db.Decimal(18, 2)
  currentValue        Decimal               @default(0) @db.Decimal(18, 2)
  unitsHeld           Decimal?              @db.Decimal(18, 6)
  isRetirement        Boolean               @default(false)
  isArchived          Boolean               @default(false)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        InvestmentTransaction[]

  @@index([userId])
  @@unique([userId, accountName])
}

model InvestmentTransaction {
  id                  String                    @id @default(uuid()) @db.Uuid
  investmentAccountId String                    @db.Uuid
  transactionDate     DateTime
  transactionType     InvestmentTransactionType
  quantity            Decimal?                  @db.Decimal(18, 6)
  pricePerUnit        Decimal?                  @db.Decimal(18, 6)
  totalAmount         Decimal                   @db.Decimal(18, 2)
  fees                Decimal?                  @db.Decimal(18, 2)
  notes               String?
  createdAt           DateTime                  @default(now())

  investmentAccount   InvestmentAccount         @relation(fields: [investmentAccountId], references: [id], onDelete: Cascade)

  @@index([investmentAccountId])
  @@index([transactionDate])
}

model MonthlyFinancialSnapshot {
  id                    String          @id @default(uuid()) @db.Uuid
  userId                String          @db.Uuid
  snapshotMonth         DateTime        @db.Date
  currencyCode          String          @default("LKR") @db.VarChar(10)
  totalIncome           Decimal         @default(0) @db.Decimal(18, 2)
  totalExpense          Decimal         @default(0) @db.Decimal(18, 2)
  totalSavings          Decimal         @default(0) @db.Decimal(18, 2)
  totalAssets           Decimal         @default(0) @db.Decimal(18, 2)
  totalLiabilities      Decimal         @default(0) @db.Decimal(18, 2)
  netWorth              Decimal         @default(0) @db.Decimal(18, 2)
  reimbursementPending  Decimal         @default(0) @db.Decimal(18, 2)
  upcomingBills         Decimal         @default(0) @db.Decimal(18, 2)
  healthScore           Int?
  status                SnapshotStatus  @default(OPEN)
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([snapshotMonth])
  @@unique([userId, snapshotMonth])
}

model AuditLog {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String?      @db.Uuid
  entityName      String       @db.VarChar(80)
  entityId        String?      @db.VarChar(80)
  action          AuditAction
  description     String?
  beforeData      Json?
  afterData       Json?
  createdBy       String?      @db.VarChar(150)
  createdAt       DateTime     @default(now())

  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityName, entityId])
  @@index([createdAt])
}

model ImportJob {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @db.Uuid
  jobType         String          @db.VarChar(50)
  sourceName      String?         @db.VarChar(150)
  fileName        String?         @db.VarChar(255)
  status          ImportJobStatus @default(PENDING)
  totalRows       Int             @default(0)
  successRows     Int             @default(0)
  failedRows      Int             @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  errorLog        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}